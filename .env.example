# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/madre?schema=public"

# Secret used to sign session cookies (HMAC). Minimum 32 bytes.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me"

# Directory (dev) or bucket mount for private employee documents.
# Production: EU-region private bucket with signed URLs + art.28 RGPD DPA.
STORAGE_DIR="./storage"
