# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/madre?schema=public"

# Secret used to sign session cookies (HMAC). Minimum 32 bytes.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me"

# Directory (dev) or bucket mount for private employee documents.
# Production: EU-region private bucket with signed URLs + art.28 RGPD DPA.
STORAGE_DIR="./storage"

# Optional email (password recovery, notifications). Leave unset in dev — the
# mailer then logs the message to the server console. Use an EU SMTP provider.
#   SMTP_URL="smtps://user:pass@smtp.eu-provider.com:465"
#   MAIL_FROM="MADRE <no-reply@cortedemanga.es>"
SMTP_URL=""
MAIL_FROM=""

# Web Push (notificaciones PWA). Sin claves, el push queda desactivado.
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:tu-admin@dominio.es"
