// MADRE — data model
// Non-negotiable principles baked in here (spec §2):
//  1. Autogestión: everything is data, nothing hardcoded.
//  2. Multi-local: every domain entity carries `localId`.
//  3. Trazabilidad: AuditLog is append-only (no update/delete in app code).
//  4. Conservación legal: soft-delete (deletedAt) so 4-year history is kept.

generator client {
  provider      = "prisma-client-js"
  // "native" para desarrollo local; "rhel-openssl-3.0.x" cubre el runtime
  // AWS Lambda que usan Netlify Functions y Vercel. Sin esto, el motor de
  // Prisma generado en el build no coincide con el runtime de producción y
  // cada consulta lanza una excepción de servidor (causa típica del error
  // genérico "Application error" en Netlify).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Core / access
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPERADMIN // propiedad: todo, todos los locales
  ENCARGADO // su local
  EMPLEADO // su información
  GESTORIA // fase 2: nóminas + registro horario
}

model Local {
  id        String   @id @default(cuid())
  code      String   @unique // p.ej. "CDM"
  name      String // "Corte de Manga"
  active    Boolean  @default(true)
  alertLeadDays Int   @default(30) // antelación por defecto de avisos de caducidad
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  employees     Employee[]
  vacationYears VacationYear[]
  blockedWeeks  BlockedWeek[]
  shifts        Shift[]
  documents     Document[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role
  active       Boolean   @default(true)
  localId      String? // null solo para SUPERADMIN (acceso a todos)
  local        Local?    @relation(fields: [localId], references: [id])
  employee     Employee?

  // recuperación autónoma de contraseña (spec §3)
  resetToken     String?   @unique
  resetExpiresAt DateTime?
  mustChangePassword Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions  Session[]
  pushSubscriptions PushSubscription[]

  @@index([localId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  ip        String?
  userAgent String?

  @@index([userId])
}

// Append-only. The app never updates or deletes rows here (spec §2.3).
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  actorId   String? // user who performed the action (null = system)
  actorEmail String? // denormalised so the log survives user deletion
  localId   String?
  action    String // e.g. "vacation.approve"
  entity    String // e.g. "VacationRequest"
  entityId  String?
  detail    Json? // structured before/after or context
  ip        String?

  @@index([entity, entityId])
  @@index([localId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Employees (núcleo — spec §4.1)
// ─────────────────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVO
  BAJA
  EXCEDENCIA
}

enum ContractType {
  INDEFINIDO
  TEMPORAL
  FIJO_DISCONTINUO
  FORMACION
  PRACTICAS
}

model Employee {
  id     String @id @default(cuid())
  localId String
  local  Local  @relation(fields: [localId], references: [id])

  // 1:1 login. Nullable so an employee record can exist before access is provisioned.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Datos personales
  firstName String
  lastName  String
  nif       String? // NIF/NIE
  ssNumber  String? // nº Seguridad Social
  iban      String?
  phone     String?
  email     String?
  emergencyContact String?
  emergencyPhone   String?

  // Contrato
  contractType     ContractType   @default(INDEFINIDO)
  weeklyHours      Float          @default(40) // jornada
  startDate        DateTime
  endDate          DateTime? // fin de contrato temporal
  trialEndDate     DateTime? // fin del período de prueba
  status           EmployeeStatus @default(ACTIVO)

  // Vacaciones: por defecto hereda del año configurado; puede overridearse por empleado.
  vacationDaysOverride Int?

  // Fichaje: PIN de tablet (hasheado, sin biometría — criterio AEPD spec §5).
  pinHash String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete (baja) — histórico conservado 4 años

  vacationRequests   VacationRequest[]
  vacationAdjustments VacationAdjustment[]
  shifts             Shift[]
  documents          Document[]
  documentAcks       DocumentAck[]
  timeEntries        TimeEntry[]
  absences           Absence[]
  incidents          Incident[]
  expiries           Expiry[]
  manualReads        ManualRead[]
  announcementReads  AnnouncementRead[]

  @@index([localId, deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Vacaciones (motor de reglas — spec §4.2)
// ─────────────────────────────────────────────────────────────────────────────

enum PriorityRule {
  ORDEN_SOLICITUD // orden de llegada
  ANTIGUEDAD // fecha de alta más antigua
  ROTACION // rotación anual (informativo)
}

// Configuración anual por local. El validador de capacidad usa estos números.
model VacationYear {
  id      String @id @default(cuid())
  localId String
  local   Local  @relation(fields: [localId], references: [id])
  year    Int

  daysPerEmployee  Int          @default(30) // 30 naturales según Convenio Hostelería CAT
  weeksPerEmployee Int          @default(5) // semanas completas asignables por persona
  accrualPerMonth  Float        @default(2.5) // devengo días naturales/mes
  priorityRule     PriorityRule @default(ORDEN_SOLICITUD)
  requestsOpen     Boolean      @default(false) // el admin abre solicitudes tras validar capacidad

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([localId, year])
}

// Semanas bloqueadas (temporada alta). Configurables por año — nunca hardcode.
model BlockedWeek {
  id      String @id @default(cuid())
  localId String
  local   Local  @relation(fields: [localId], references: [id])
  year    Int
  week    Int // número de semana ISO (1..53)
  reason  String?

  createdAt DateTime @default(now())

  @@unique([localId, year, week])
  @@index([localId, year])
}

enum VacationStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

model VacationRequest {
  id         String   @id @default(cuid())
  localId    String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  year       Int

  status       VacationStatus @default(PENDIENTE)
  decisionNote String? // motivo de rechazo
  decidedById  String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeks VacationWeek[]

  @@index([localId, year, status])
  @@index([employeeId])
}

model VacationWeek {
  id        String          @id @default(cuid())
  requestId String
  request   VacationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  localId   String
  year      Int
  week      Int // semana ISO
  startDate DateTime
  endDate   DateTime

  // Regla anti-solapamiento ABSOLUTA: una semana ISO aprobada es única por local+año.
  // El índice único se aplica solo a semanas de solicitudes APROBADAS mediante una
  // columna espejo `approvedKey` (ver lógica en lib/vacations). Aquí guardamos todas.
  approvedKey String? @unique // = `${localId}:${year}:${week}` cuando la solicitud está aprobada

  @@index([localId, year, week])
}

// Bolsa de días: ajustes manuales (festivos trabajados, días pendientes de devolución).
enum AdjustmentStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

model VacationAdjustment {
  id         String   @id @default(cuid())
  localId    String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  year       Int
  days       Float // positivo = días a favor del empleado
  reason     String
  desiredDate DateTime?
  status     AdjustmentStatus @default(PENDIENTE)
  decidedById String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([employeeId, year])
}

// ─────────────────────────────────────────────────────────────────────────────
// Horarios (spec §4.3) — MVP: cuadrante por empleado/día
// ─────────────────────────────────────────────────────────────────────────────

model Shift {
  id         String   @id @default(cuid())
  localId    String
  local      Local    @relation(fields: [localId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date      DateTime // día del turno (00:00)
  startTime String // "HH:mm"
  endTime   String // "HH:mm"
  note      String?
  published Boolean  @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  swaps ShiftSwap[]

  @@index([localId, date])
  @@index([employeeId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Documentos (spec §4.5) — repositorio + confirmación de recepción
// ─────────────────────────────────────────────────────────────────────────────

enum DocumentType {
  NOMINA
  CONTRATO
  ANEXO
  AMONESTACION
  COMUNICACION
  OTRO
}

model Document {
  id         String       @id @default(cuid())
  localId    String
  local      Local        @relation(fields: [localId], references: [id])
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id])
  type       DocumentType
  title      String
  period     String? // p.ej. "2026-07" para nóminas
  fileName   String
  storageKey String // ruta en STORAGE_DIR / bucket
  mimeType   String
  sizeBytes  Int
  requiresAck Boolean     @default(true)

  uploadedById String?
  createdAt    DateTime @default(now())

  acks DocumentAck[]

  @@index([localId, employeeId])
}

// Firma digital simple: clic + fecha/hora/IP (spec §4.5)
model DocumentAck {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  ackedAt    DateTime @default(now())
  ip         String?

  @@unique([documentId, employeeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 2
// ─────────────────────────────────────────────────────────────────────────────

// ── Fichaje (spec §4.4) — reconstruido en MADRE, tablet de barra, PIN, sin biometría
model TimeEntry {
  id         String    @id @default(cuid())
  localId    String
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  clockIn    DateTime
  clockOut   DateTime?
  source     String    @default("TABLET") // origen del fichaje
  createdAt  DateTime  @default(now())

  // Registro inmutable: las correcciones NO editan en silencio; quedan anotadas.
  corrections TimeCorrection[]

  @@index([localId, clockIn])
  @@index([employeeId, clockIn])
}

model TimeCorrection {
  id          String   @id @default(cuid())
  timeEntryId String
  entry       TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  field       String // "clockIn" | "clockOut"
  oldValue    DateTime?
  newValue    DateTime?
  reason      String
  authorId    String?
  authorEmail String?
  createdAt   DateTime @default(now())

  @@index([timeEntryId])
}

// ── Ausencias y permisos (spec §4.8)
enum AbsenceType {
  BAJA_MEDICA
  MATRIMONIO
  MUDANZA
  FALLECIMIENTO
  NACIMIENTO
  DEBER_PUBLICO
  LACTANCIA
  OTRO
}

enum AbsenceStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

model Absence {
  id         String        @id @default(cuid())
  localId    String
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  type       AbsenceType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     AbsenceStatus @default(PENDIENTE)
  decisionNote String?
  decidedById  String?
  decidedAt    DateTime?

  // Justificante adjunto (baja médica, etc.)
  justFileName   String?
  justStorageKey String?
  justMimeType   String?

  createdAt DateTime @default(now())

  @@index([localId, status])
  @@index([employeeId])
}

// ── Manual del bar (spec §4.6) — wiki editable + lectura confirmada + versionado
model ManualSection {
  id                  String   @id @default(cuid())
  localId             String
  slug                String
  title               String
  content             String   @db.Text
  order               Int      @default(0)
  version             Int      @default(1)
  requiresReadConfirm Boolean  @default(true)
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reads ManualRead[]

  @@unique([localId, slug])
  @@index([localId, order])
}

model ManualRead {
  id         String        @id @default(cuid())
  sectionId  String
  section    ManualSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  version    Int // versión leída — si la sección sube de versión, se pide relectura
  readAt     DateTime      @default(now())
  ip         String?

  @@unique([sectionId, employeeId, version])
}

// ── Tablón de anuncios (spec §4.10)
model Announcement {
  id           String   @id @default(cuid())
  localId      String? // null = todos los locales (solo superadmin)
  title        String
  body         String   @db.Text
  requiresRead Boolean  @default(false)
  createdById  String?
  createdByEmail String?
  createdAt    DateTime @default(now())

  reads AnnouncementRead[]

  @@index([localId, createdAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, employeeId])
}

// ── Alertas y caducidades (spec §4.9)
enum ExpiryType {
  CARNET_MANIPULADOR
  FORMACION_ALERGENOS
  NIE
  DNI
  CONTRATO_TEMPORAL
  PERIODO_PRUEBA
  OTRO
}

model Expiry {
  id         String     @id @default(cuid())
  localId    String
  employeeId String
  employee   Employee   @relation(fields: [employeeId], references: [id])
  type       ExpiryType
  label      String?
  dueDate    DateTime
  resolved   Boolean    @default(false)
  createdById String?
  createdAt  DateTime   @default(now())

  @@index([localId, dueDate])
  @@index([employeeId])
}

// ── Registro de incidencias (spec §4.11) — solo admin/encargado
model Incident {
  id          String   @id @default(cuid())
  localId     String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime
  category    String? // rendimiento / disciplina
  description String   @db.Text
  fileName    String?
  storageKey  String?
  mimeType    String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([localId, date])
}

// ── Cierre de caja (spec §4.7) — módulo interno bajo el login de MADRE
model CashClose {
  id           String   @id @default(cuid())
  localId      String
  businessDate DateTime
  openingFloat Float    @default(0) // fondo de caja
  cashCounted  Float // efectivo contado
  cardTotal    Float    @default(0) // tarjeta / datáfono
  otherTotal   Float    @default(0) // otros medios
  expectedCash Float? // efectivo esperado (opcional)
  notes        String?
  createdById  String?
  createdByEmail String?
  createdAt    DateTime @default(now())

  @@index([localId, businessDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// FASE 3+ · extras
// ─────────────────────────────────────────────────────────────────────────────

// Intercambio de turnos (spec §4.3): propuesta → aceptación compañero → visto bueno.
enum SwapStatus {
  PROPUESTO
  ACEPTADO_COMPANERO
  RECHAZADO_COMPANERO
  APROBADO
  RECHAZADO_ENCARGADO
  CANCELADO
}

model ShiftSwap {
  id               String     @id @default(cuid())
  localId          String
  shiftId          String
  shift            Shift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requestedById    String // employee que cede el turno
  targetEmployeeId String // employee al que se le ofrece
  status           SwapStatus @default(PROPUESTO)
  note             String?
  companionAt      DateTime?
  decidedById      String?
  decidedAt        DateTime?
  createdAt        DateTime   @default(now())

  @@index([localId, status])
  @@index([targetEmployeeId, status])
}

// Plantillas de semana tipo (spec §4.3).
model ScheduleTemplate {
  id          String   @id @default(cuid())
  localId     String
  name        String
  // data: [{ employeeId, weekday(0=Lun..6=Dom), startTime, endTime, note }]
  data        Json
  createdById String?
  createdAt   DateTime @default(now())

  @@index([localId])
}

// Imágenes del manual (spec §4.6) — almacenadas en bucket privado.
model ManualMedia {
  id          String   @id @default(cuid())
  localId     String
  fileName    String
  storageKey  String
  mimeType    String
  createdById String?
  createdAt   DateTime @default(now())

  @@index([localId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORAZÓN DEL BAR · nivel 1 (APPCC, checklists, parte de turno, push, propinas)
// ─────────────────────────────────────────────────────────────────────────────

// ── APPCC / seguridad alimentaria (registro legal obligatorio) ──────────────
enum AppccKind {
  NUMERIC // temperaturas, acidez del aceite…
  BOOLEAN // limpieza hecha sí/no
  TEXT // proveedor, lote, observación
}

enum AppccFrequency {
  POR_TURNO
  DIARIO
  SEMANAL
}

// Punto de control configurable por el admin (cero hardcode).
model AppccPoint {
  id          String         @id @default(cuid())
  localId     String
  name        String // "Nevera 1", "Aceite freidora"
  category    String // TEMPERATURA / RECEPCION / LIMPIEZA / ACEITE / TRAZABILIDAD / OTRO
  kind        AppccKind      @default(NUMERIC)
  unit        String? // "°C"
  minValue    Float?
  maxValue    Float?
  frequency   AppccFrequency @default(DIARIO)
  active      Boolean        @default(true)
  order       Int            @default(0)
  createdById String?
  createdAt   DateTime       @default(now())

  records AppccRecord[]

  @@index([localId, active])
}

// Registro inmutable: quién, cuándo, valor y si es conforme.
model AppccRecord {
  id             String     @id @default(cuid())
  localId        String
  pointId        String
  point          AppccPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)
  numValue       Float?
  boolValue      Boolean?
  textValue      String?
  ok             Boolean // dentro de umbral / conforme
  note           String?
  recordedById   String?
  recordedByName String?
  recordedAt     DateTime   @default(now())
  ip             String?

  @@index([localId, recordedAt])
  @@index([pointId, recordedAt])
}

// ── Checklists de apertura / cierre ─────────────────────────────────────────
enum ChecklistMoment {
  APERTURA
  CIERRE
  OTRO
}

model ChecklistTemplate {
  id          String          @id @default(cuid())
  localId     String
  name        String
  moment      ChecklistMoment @default(APERTURA)
  active      Boolean         @default(true)
  order       Int             @default(0)
  createdById String?
  createdAt   DateTime        @default(now())

  items ChecklistItem[]
  runs  ChecklistRun[]

  @@index([localId, active])
}

model ChecklistItem {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int               @default(0)

  checks ChecklistCheck[]
}

model ChecklistRun {
  id           String            @id @default(cuid())
  localId      String
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  businessDate DateTime
  createdAt    DateTime          @default(now())

  checks ChecklistCheck[]

  @@unique([templateId, businessDate])
  @@index([localId, businessDate])
}

model ChecklistCheck {
  id      String        @id @default(cuid())
  runId   String
  run     ChecklistRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  itemId  String
  item    ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  checked Boolean       @default(true)
  note    String?
  byId    String?
  byName  String?
  at      DateTime      @default(now())

  @@unique([runId, itemId])
}

// ── Parte de turno (relevo) ─────────────────────────────────────────────────
model ShiftLog {
  id           String         @id @default(cuid())
  localId      String
  businessDate DateTime
  shift        String? // "Mañana", "Tarde", "Noche"
  body         String         @db.Text
  authorId     String?
  authorName   String?
  createdAt    DateTime       @default(now())

  reads ShiftLogRead[]

  @@index([localId, businessDate])
}

model ShiftLogRead {
  id         String   @id @default(cuid())
  logId      String
  log        ShiftLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  employeeId String
  readAt     DateTime @default(now())

  @@unique([logId, employeeId])
}

// ── Notificaciones push (Web Push) ──────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Propinas ────────────────────────────────────────────────────────────────
enum TipMethod {
  EQUAL // a partes iguales
  BY_HOURS // proporcional a horas fichadas ese día
  MANUAL // importes introducidos a mano
}

model TipPool {
  id           String     @id @default(cuid())
  localId      String
  businessDate DateTime
  shift        String?
  totalAmount  Float
  method       TipMethod  @default(EQUAL)
  note         String?
  createdById  String?
  createdAt    DateTime   @default(now())

  shares TipShare[]

  @@index([localId, businessDate])
}

model TipShare {
  id         String  @id @default(cuid())
  poolId     String
  pool       TipPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  employeeId String
  amount     Float

  @@index([employeeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// NIVEL 2 · Onboarding de altas + Formación/PRL
// ─────────────────────────────────────────────────────────────────────────────

// Onboarding: plantilla de incorporación configurable + progreso por empleado.
model OnboardingTemplate {
  id          String   @id @default(cuid())
  localId     String
  name        String
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())

  items OnboardingItem[]

  @@index([localId, active])
}

model OnboardingItem {
  id         String             @id @default(cuid())
  templateId String
  template   OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int                @default(0)

  checks OnboardingCheck[]
}

model OnboardingCheck {
  id         String         @id @default(cuid())
  localId    String
  employeeId String
  itemId     String
  item       OnboardingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  done       Boolean        @default(false)
  note       String?
  byId       String?
  byName     String?
  at         DateTime       @default(now())

  @@unique([employeeId, itemId])
  @@index([localId, employeeId])
}

// Formación / PRL: cursos con seguimiento y renovaciones (enlazan con caducidades).
model Course {
  id             String   @id @default(cuid())
  localId        String
  name           String // "Manipulador de alimentos", "Alérgenos", "PRL"
  validityMonths Int? // meses de validez para renovación; null = no caduca
  active         Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())

  completions CourseCompletion[]

  @@index([localId, active])
}

model CourseCompletion {
  id          String    @id @default(cuid())
  localId     String
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employeeId  String
  completedOn DateTime
  expiresOn   DateTime? // completedOn + validityMonths
  fileName    String?
  storageKey  String?
  mimeType    String?
  createdById String?
  createdAt   DateTime  @default(now())

  @@index([employeeId])
  @@index([localId, expiresOn])
}
